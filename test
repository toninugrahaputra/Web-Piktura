    <script>
    function filterPortfolio(category) {
        document.querySelectorAll('.portfolio-btn').forEach(btn => {
            btn.classList.remove('text-black', 'bg-white', 'font-bold', 'shadow-sm');
            btn.classList.add('text-gray-500', 'font-medium');
        });

        const activeBtn = document.getElementById('btn-' + category);
        if (activeBtn) {
            activeBtn.classList.add('text-black', 'bg-white', 'font-bold', 'shadow-sm');
            activeBtn.classList.remove('text-gray-500', 'font-medium');
        }

        document.querySelectorAll('.portfolio-item').forEach(item => {
            const isMatch = category === 'all' || item.getAttribute('data-cat') === category;

            if (isMatch) {
                item.style.display = 'block'; 
                requestAnimationFrame(() => {
                    item.style.opacity = '1';
                    item.style.transform = 'scale(1)';
                    item.style.transition = 'all 0.4s ease-in-out';
                });
            } else {
                item.style.opacity = '0';
                item.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    if (item.style.opacity === '0') {
                        item.style.display = 'none';
                    }
                }, 400); 
            }
        });
    }
    </script>